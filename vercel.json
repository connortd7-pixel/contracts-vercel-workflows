{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "functions": {
    "api/compare.py": {
      "maxDuration": 30
    },
    "api/analyze.py": {
      "maxDuration": 60
    }
  }
}
